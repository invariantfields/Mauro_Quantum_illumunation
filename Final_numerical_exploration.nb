        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"-", 
             RowBox[{"Log", "[", 
              FractionBox[
               RowBox[{"2", " ", 
                RowBox[{"Gs", "[", 
                 RowBox[{"d0", ",", "s"}], "]"}], " ", 
                RowBox[{"Gs", "[", 
                 RowBox[{"d1", ",", 
                  RowBox[{"1", "-", "s"}]}], "]"}]}], 
               RowBox[{
                RowBox[{"\[CapitalLambda]s", "[", 
                 RowBox[{"d0", ",", "s"}], "]"}], "+", 
                RowBox[{"\[CapitalLambda]s", "[", 
                 RowBox[{"d1", ",", 
                  RowBox[{"1", "-", "s"}]}], "]"}]}]], "]"}]}], "+", 
            FractionBox[
             RowBox[{"2", "*", "k", "*", " ", "m"}], 
