 RowBox[{
  RowBox[{
   RowBox[{"ComputeChernoff1", "[", 
    RowBox[{"n_", ",", "m_", ",", "k_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"d0", "=", 
